{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && tsc server.ts --outDir dist --module esnext --moduleResolution node --esModuleInterop --skipLibCheck",
    "start": "node dist/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "better-sqlite3": "^12.4.1",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "dotenv": "^17.2.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@tailwindcss/vite": "^4.1.14",
    "tailwindcss": "^4.1.14",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.4.49",
    "vite-plugin-pwa": "^0.21.1",
    "@types/node": "^22.14.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.18.1",
    "@types/better-sqlite3": "latest",
    "@types/uuid": "^10.0.0"
  },
  "devDependencies": {}
  "overrides": {
    "node-domexception": "file:./node-domexception"
  }
